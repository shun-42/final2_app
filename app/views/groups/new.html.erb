<div class="container">
  <div class="row">
    <div class="col-sm-12 col-md-8 col-lg-5 px-5 px-sm-0 mx-auto">
      <h2>Create Group</h2>
      
      <%# @group を使うので、コントローラの new アクションで @group = Group.new が必要です %>
      <%= form_with model: @group do |f| %>
        <div class="form-group">
          <label for="group_name">グループ名</label>
          <%= f.text_field :name, class: 'form-control group_name' %>
        </div>
        
        <div class="form-group">
          <label for="group_introduction">紹介文</label>
          <%= f.text_area :introduction, class: 'form-control group_introduction' %>
        </div>
        
        <div class="form-group">
          <label for="group_image">グループ画像</label>
          <%= f.file_field :image, class: 'form-control-file group_image', accept: 'image/*' %>
        </div>
        
        <div class="form-group">
          <%= f.submit 'Create Group', class: 'btn btn-info' %>
        </div>
      <% end %>
    </div>
  </div>
</div>