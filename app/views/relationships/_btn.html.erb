<% if Current.user != user%>
  <% if Current.user.following?(user) %>
    <%= link_to "フォロー外す", user_relationships_path(user.id), data: { turbo_method: :delete }, class: "btn btn-info" %>
  <% else %>
    <%= link_to "フォローする", user_relationships_path(user.id), data: { turbo_method: :post }, class: "btn btn-success" %>
  <% end %>
<% end %>
