<div class='container px-5 px-sm-0'>
  <div class='row'>
    <div class='col-md-3'>
      <h2>User info</h2>
      <%= render '/users/info', user: @user %>
    </div>
    <div class='col-md-8 offset-md-1'>
      <h1 id="room" data-room="<%= @room.id %>" data-user="<%= Current.user.id %>"><%= @user.name %> さんとのチャット</h1>

      <div class="message" style="width: 400px;">
        <%= turbo_frame_tag "chat_message" do %>
          <% @chats.each do |chat| %>
            <%= render "chats/message", chat: chat %>
          <% end %>
        <% end %>
      </div>
      <%= turbo_frame_tag "chat-form" do %>
        <%= render "chats/form", chat: @chat %>
      <% end %>
    </div>
  </div>
</div>
