<div class="container">
  <h2><%= @user.name %>さんとのチャット</h2>

  <div class="message-box">
    <% @chats.each do |chat| %>
     <p <% if chat.user == Current.user %> style="text-align: right;" <% end %>>
           <%= chat.message %>
     </p>
    <% end %> 
  </div>
  <%= form_with model: @chat, local: true do |f| %>
    <%= f.text_field :message %>
    <%= f.hidden_field :room_id, value: @room.id %>
    <%= f.submit "送信" %>
  <% end %>

</div>