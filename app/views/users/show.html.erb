<div class='container px-5 px-sm-0'>
  <div class='row'>
    
    <div class='col-md-3'>
      <h2>User info</h2>
      <table class='table'>
        <tr>
          <%= image_tag @user.get_profile_image(100,100) %>
        </tr>
        <tr>
          <th>name</th>
          <th><%= @user.name %></th> 
        </tr>
        <tr>
          <th>introduction</th>
          <th><%= @user.introduction %></th> 
        </tr>
      </table>
      <div class='row'>
        <%= link_to edit_user_path(@user), class: "btn btn-outline-secondary btn-block" do %>
          <i class="fas fa-user-cog"></i>
        <% end %>
      </div>
      <% if Current.user != @user %>
        <div class="mt-3">
          <% if Current.user.following?(@user) %>
              <%# link_to ではなく button_to を使う %>
            <%= button_to "フォロー外す", user_relationships_path(@user.id), method: :delete, class: "btn btn-info btn-block" %>
          <% else %>
              <%# link_to ではなく button_to を使う %>
            <%= button_to "フォローする", user_relationships_path(@user.id), method: :post, class: "btn btn-success btn-block" %>
          <% end %>
          <% if Current.user.following?(@user) && @user.following?(Current.user) %>
            <div class="mt-2">
              <%= link_to 'chatを始める', chat_path(@user.id), class: "btn btn-primary btn-block" %>
            </div>
          <% end %>
        </div>
      <% end %>
      <h2 class="mt-3">New book</h2>
      <%= form_with model: Book.new do |f| %>
        <div class="form-group">
          <label for="book_title">Title</label>
          <%= f.text_field :title, class: 'form-control' %>
        </div>
        <div class="form-group">
          <label for="book_opinion">Opinion</label>
          <%= f.text_area :body, class: 'form-control' %>
        </div>
        <div class="form-group">
          <%= f.submit 'Create Book', class: 'btn btn-success' %>
        </div>
      <% end %>
    </div>
    <div class='col-md-8 offset-md-1'>
      <h2>Books</h2>
      <table class='table table-hover table-inverse'>
        <thead>
          <tr>
            <th></th>
            <th>Title</th>
            <th>Opinion</th>
            <th>コメント数</th>
            <th>いいね</th>
            <th colspan="3"></th>
          </tr>
        </thead>
        <tbody>        
          <% @user.books.each do |book| %>
            <tr>
              <td>
                 <%= link_to user_path(book.user) do %>
                    <%= image_tag @user.get_profile_image(100,100) %>
                 <% end %>
              </td>
              <td><%= link_to book.title, book_path(book) %></td>
              <td><%= book.body %></td>
              <td>
                <%= link_to "#{book.post_comments.count} コメント", book_path(book.id) %>
               </td>
            </tr>
          <% end %>
        </tbody>
      </table>
      <h3>投稿数の前日比・前週比</h3>
        <div class="table_width">
          <table class='table table-bordered'>
            <thead>
              <tr>
                <th>今日の投稿数</th>
                <th>前日の投稿数</th>
                <th>前日比</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td><%= @today_book.count %></td>
                <td><%= @yesterday_book.count %></td>
                <td>
                  <% if @yesterday_book.count == 0 %>
                    前日の投稿が0のため計算できません
                  <% else %>
                    <% @the_day_before = @today_book.count / @yesterday_book.count.to_f %>
                    <%= (@the_day_before * 100).round %>%
                  <% end %>
                </td>
              </tr>
            </tbody>
          </table>
        </div>
        <div class="table_width">
          <table class='table table-bordered'>
            <thead>
              <tr>
                <th>今週の投稿数</th>
                <th>前週の投稿数</th>
                <th>前週比</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td><%= @this_week_book.count %></td>
                <td><%= @last_week_book.count %></td>
                <td>
                  <% if @last_week_book.count == 0 %>
                    前週の投稿が0のため計算できません
                  <% else %>
                    <% @the_week_before = @this_week_book.count / @last_week_book.count.to_f %>
                    <%= (@the_week_before * 100).round %>%
                  <% end %>
                </td>
              </tr>
            </tbody>
          </table>
        </div>
        <h3>7日間分の投稿数</h3>
        <table class="table table-bordered">
          <thead>
            <tr>
              <th>6日前</th>
              <th>5日前</th>
              <th>4日前</th>
              <th>3日前</th>
              <th>2日前</th>
              <th>1日前</th>
              <th>今日</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td><%= @books_6days_ago.count %></td>
              <td><%= @books_5days_ago.count %></td>
              <td><%= @books_4days_ago.count %></td>
              <td><%= @books_3days_ago.count %></td>
              <td><%= @books_2days_ago.count %></td>
              <td><%= @books_yesterday.count %></td>
              <td><%= @books_today.count %></td>
            </tr>
          </tbody>
        </table>
        <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
      <canvas id="myLineChart"></canvas>
      <script>
        document.addEventListener("turbo:load", function () {
        const canvas = document.getElementById("myLineChart");
        if (!canvas) return; // canvas が存在しないページでは何もしない

        // window.myLineChart が Chart.js オブジェクトかどうか確認
        if (window.myLineChart && typeof window.myLineChart.destroy === "function") {
          window.myLineChart.destroy();
        }
        const ctx = canvas.getContext("2d");
        window.myLineChart = new Chart(ctx, {
          type: 'line',
          data: {
            labels: ['6日前', '5日前', '4日前', '3日前', '2日前', '1日前', '今日'],
            datasets: [
              {
                label: '投稿した本の数',
                data: [
                  <%= @books.created_6days_ago.count %>,
                  <%= @books.created_5days_ago.count %>,
                  <%= @books.created_4days_ago.count %>,
                  <%= @books.created_3days_ago.count %>,
                  <%= @books.created_2days_ago.count %>,
                  <%= @books.created_yesterday.count %>,
                  <%= @books.created_today.count %>
                ],
                borderColor: "rgba(0,0,255,1)",
                backgroundColor: "rgba(0,0,0,0)"
              }
            ],
          },
          options: {
            plugins: {
              title: {
                display: true,
                text: '7日間の投稿数の比較'
              }
            },
            scales: {
              y: {
                suggestedMax: 10,
                suggestedMin: 0,
                ticks: {
                  stepSize: 1,
                  callback: function(value, index, values){
                    return value;
                  }
                }
              }
            }
          }
        });
      });    
      </script>
      <div>
        <%# 修正：data: { turbo_stream: true } を削除して local: true にします %>
        <%= form_with url: user_search_path(@user), method: :get, local: true do |f| %>
          <%= f.date_field :created_at %>
          <%= f.submit '検索', class: 'btn btn-primary' %>
        <% end %>

        <%# 検索結果を表示するエリア %>
        <div id="search_result">
          <% if params[:created_at].present? %>
            <%= render 'users/search', search_book: @search_book %>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>