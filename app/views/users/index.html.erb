<div class="container px-5 px-sm-0">
  <div class="row">
    <div class="col-md-3">
      <h2>User info</h2>
      <% if Current.user %>
        <%= image_tag Current.user.get_profile_image(100,100) if Current.user.respond_to?(:get_profile_image) %>       
        <table class="table">
          <tbody>
            <tr>
              <th>name</th>
              <th><%= Current.user.name %></th>
            </tr>
            <tr>
              <th>introduction</th>
              <th><%= Current.user.introduction %></th>
            </tr>
            <tr>
               <th>follows</th>
               <th><%= link_to Current.user.followings.count, user_followings_path(Current.user) %></th>
            </tr>
            <tr>
              <th>followers</th>
              <th><%= link_to Current.user.followers.count, user_followers_path(Current.user) %></th>
            </tr>
          </tbody>
        </table>
      <% end %>  
      <div class='row'>
        <%= link_to edit_user_path(@user), class: "btn btn-outline-secondary btn-block" do %>
          <i class="fas fa-user-cog"></i>
        <% end %>
      </div>
      <h2 class="mt-3">New book</h2>
      <%= form_with model: Book.new do |f| %>
        <div class="form-group">
          <label for="book_title">Title</label>
          <%= f.text_field :title, class: 'form-control' %>
        </div>
        <div class="form-group">
          <label for="book_opinion">Opinion</label>
          <%= f.text_area :body, class: 'form-control' %>
        </div>
        <div class="form-group">
          <%= f.submit 'Create Book', class: 'btn btn-success' %>
        </div>
      <% end %>
    </div>

    <div class="col-md-8 offset-md-1">
      <h2>Users</h2>
      <%= link_to 'グループを作成する', new_group_path %> | <%= link_to 'グループ一覧', groups_path %>
      <table class="table table-hover">
        <thead>
          <tr>
            <th>image</th>
            <th>name</th>
            <th colspan="3"></th>
          </tr>
        </thead>
        <tbody>
          <% @users.each do |user| %>
            <tr>
              <td>
                <%= image_tag user.get_profile_image(40,40) if user.respond_to?(:get_profile_image) %>
              </td>
              <td><%= user.name %></td>
              <td>フォロー数: <%= user.followings.count %></td>
              <td>フォロワー数: <%= user.followers.count %></td>
              <td>
                <% if Current.user != user %>
                  <% if Current.user.following?(user) %>
                    <%= link_to "フォロー外す", user_relationships_path(user.id), data: { turbo_method: :delete } %>
                  <% else %>
                    <%= link_to "フォローする", user_relationships_path(user.id), data: { turbo_method: :post } %>
                  <% end %>
                <% end %>
              </td>
              <td><%= link_to "Show", user_path(user.id) %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>