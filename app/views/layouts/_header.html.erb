<header>
	   <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
	     <div class="container">
	       <a class="navbar-brand" href="/"><span>Bookers</span></a>
	       <button class="navbar-toggler" type="button" data-toggle="collapse" data-target="#navbarNavDropdown" aria-controls="navbarNavDropdown" aria-expanded="false" aria-label="Toggle navigation">
	        <span class="navbar-toggler-icon"></span>
	      </button>
	      <div class="collapse navbar-collapse" id="navbarNavDropdown">
	        <ul class="navbar-nav ms-auto">
            <% if authenticated? %>
							<li>
								<%= link_to user_path(Current.user), class: "nav-link text-light" do %>
									<i class="fa-solid fa-house"></i> Home
								<% end %>
							</li>
							<li>
								<%= link_to users_path, class: "nav-link text-light" do %>
									<i class="fa-solid fa-users"></i> Users
								<% end %>
							</li>
							<li>
								<%= link_to books_path, class: "nav-link text-light" do %>
									<i class="fa-solid fa-book-open"></i> Books
								<% end %>
							</li>
							<li>
								<%= link_to session_path, data: { turbo_method: :delete }, class: "nav-link text-light" do %>
									<i class="fa-solid fa-right-to-bracket fa-solidfa-sign-out-alt fas fa-sign-out-alt "></i> Log out
								<% end %>
						  </li> 
							<li>
								<div class="search_form">
									<%= form_with url: search_path, local: true, method: :get, class: "d-flex" do |f| %>
										<%= f.text_field :word, class: "form-control" %>
										<%= f.select :range, options_for_select([['User'], ['Book']]), {}, {class: "form-select"} %>
										<%= f.select :search, options_for_select([["完全一致","perfect_match"], ["前方一致","forward_match"], ["後方一致","backward_match"], ["部分一致","partial_match"]]), {}, {class: "form-select"} %>
										<%= f.submit "検索", class: "btn btn-outline-light" %>
									<% end %>
								</div>
							</li>
            <% else %>
	           <li>
	            <%= link_to root_path, class:"nav-link text-light" do%>
	             <i class="fa-solid fa-house"></i> Home
	            <% end %>
	           </li>
	           <li>
	            <%= link_to home_about_path, class:"nav-link text-light" do %>
	             <i class="fa-solid fa-link"></i> About
	            <% end %>
	           </li>
	           <li>
	            <%= link_to new_user_path, class:"nav-link text-light" do %>
	             <i class="fa-solid fa-user-plus"></i>
	             Sign up
	            <% end %>
	           </li>
	           <li>
	            <%= link_to  new_session_path, class:"nav-link text-light" do %>
	             <i class="fa-solid fa-right-to-bracket"></i>
	             Log in
	            <% end %>
	           </li>
            <% end %>
            </ul>
           </div>
         </div>
      </nav>
</header>